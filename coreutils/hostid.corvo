# Print the numeric identifier for the current host.
@parsed = args.parse(os.argv(), {})
@o = @parsed["options"]
if (@o.get("help", false)) {
  sys.echo("Usage: hostid")
  sys.echo("Print the numeric identifier for the current host.")
  sys.exit(0)
}
if (@o.get("version", false)) {
  sys.echo("hostid (Corvo coreutils) 0.1.0")
  sys.exit(0)
}
sys.echo(os.hostid())
