# Print machine architecture.
@parsed = args.parse(os.argv(), {})
@o = @parsed["options"]
if (@o.get("help", false)) {
  sys.echo("Usage: arch")
  sys.echo("Print machine architecture.")
  sys.exit(0)
}
if (@o.get("version", false)) {
  sys.echo("arch (Corvo coreutils) 0.1.0")
  sys.exit(0)
}
sys.echo(os.info()["arch"])
